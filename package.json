{
  "name": "lavanderia-sastreria-desktop",
  "version": "1.0.6",
  "private": true,
  "type": "commonjs",
  "description": "Aplicación de escritorio para gestión de lavandería y sastrería",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "masterkey:prepare": "node scripts/security/obfuscate-security-pipeline.cjs",
    "masterkey:setup": "node scripts/security/dist/master-key-setup.cjs",
    "masterkey:check": "node scripts/security/dist/pipeline-entry.cjs --mode=manual-check",
    "predev": "node scripts/security/dist/pipeline-entry.cjs --mode=dev",
    "prestart": "node scripts/security/dist/pipeline-entry.cjs --mode=start",
    "prebuild": "node scripts/security/dist/pipeline-entry.cjs --mode=build",
    "dist:local": "npm run build && electron-builder --win nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:win:publish": "npm run build && electron-builder --win nsis --publish always",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "dev:app": "wait-on http-get://localhost:5173 dist-electron/main/main.js && npx electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" \"npm run dev:app\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps && npm run masterkey:prepare"
  },
  "build": {
    "appId": "com.sistetecni.lavanderia",
    "productName": "Lavanderia y Sastreria Sistetecni",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/backend/db/migrations",
        "to": "sql/migrations",
        "filter": [
          "**/*.sql"
        ]
      },
      {
        "from": "google-oauth.json",
        "to": "google-oauth.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "santiagomontanes",
        "repo": "lavanderia-sastreria",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "beforeBuild": "scripts/security/dist/electron-before-build.cjs",
    "asarUnpack": [
      "**/*.node",
      "dist-electron/bin/**"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "asar": true
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "jsbarcode": "^3.12.3",
    "kysely": "^0.28.2",
    "mysql2": "^3.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "react-router-dom": "^6.30.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "javascript-obfuscator": "^5.4.1",
    "node-machine-id": "^1.1.12",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5",
    "wait-on": "^8.0.3"
  },
  "optionalDependencies": {
    "@alexssmusica/node-printer": "^0.8.1"
  }
}
